# Required for live agent runs (CLI + hosted demo).
# Without these the replay path (bun run demo) still works.
ANTHROPIC_API_KEY=

# Required for SAM.gov entity lookups.
# Get one at https://sam.gov → Workspace → Account Details → API Keys.
SAM_GOV_API_KEY=

# grants.gov Search API v2 is currently public/unauthenticated.
# Reserved for future stable-throughput key if grants.gov adds one.
GRANTS_GOV_API_KEY=

# Hosted-demo guardrails (web/ only — ignored by CLI).
BUDGET_MAX_USD_PER_DAY=3
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
